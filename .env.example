# Each accepted input type can be enabled independently.
CVREFORM_ACCEPT_DOCX=true
CVREFORM_ACCEPT_PDF=true

# Creates a PDF visual reference after a DOCX upload.
CVREFORM_CONVERT_DOCX_TO_PDF=true

# Optional absolute path to soffice.exe when LibreOffice is not in a standard location.
SOFFICE_PATH=
