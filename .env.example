# Backend-only secret. Add the real value to .env; never commit it or use VITE_.
OPENAI_API_KEY=

# AI request configuration. Defaults are conservative for local MVP development.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_CONCURRENT_REQUESTS=2

# Each accepted input type can be enabled independently.
CVREFORM_ACCEPT_DOCX=true
CVREFORM_ACCEPT_PDF=true

# Creates a PDF visual reference after a DOCX upload.
CVREFORM_CONVERT_DOCX_TO_PDF=true

# Render each PDF page as a visual reference and send it with the PDF to OpenAI.
CVREFORM_SEND_PAGE_IMAGES=true
CVREFORM_PAGE_IMAGE_DPI=150

# Optional absolute path to soffice.exe when LibreOffice is not in a standard location.
SOFFICE_PATH=
